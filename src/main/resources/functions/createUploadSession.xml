<template xmlns="http://ws.apache.org/ns/synapse" name="createUploadSession">
    <parameter name="responseVariable" description="The target variable in which the output of the operation will be stored"/>
    <parameter name="overwriteBody" description="Replace the Message Body in Message Context with the output payload of the operation"/>
    <parameter name="driveId" description=""/>
    <parameter name="driveItemId" description=""/>
    <parameter name="item_description" description="Provides a user-visible description of the item. Read-write. Only on OneDrive Personal."/>
    <parameter name="item_driveItemSource_application" description=""/>
    <parameter name="item_driveItemSource_externalId" description="The external identifier for the drive item from the source."/>
    <parameter name="item_fileSize" description="Provides an expected file size to perform a quota check before uploading. Only on OneDrive Personal."/>
    <parameter name="item_fileSystemInfo_createdDateTime" description="The UTC date and time the file was created on a client."/>
    <parameter name="item_fileSystemInfo_lastAccessedDateTime" description="The UTC date and time the file was last accessed. Available for the recent file list only."/>
    <parameter name="item_fileSystemInfo_lastModifiedDateTime" description="The UTC date and time the file was last modified on a client."/>
    <parameter name="item_mediaSource_contentCategory" description=""/>
    <parameter name="item_name" description="The name of the item (filename and extension). Read-write."/>
    <parameter name="headers" description=""/>
    <sequence>
        <property name="param0" value="driveId"/>
        <property name="paramType0" value="string"/>
        <property name="param1" value="driveItemId"/>
        <property name="paramType1" value="string"/>
        <property name="param2" value="payload"/>
        <property name="paramType2" value="record"/>
        <property name="param2_recordName" value="DriveItemIdMicrosoftGraphCreateUploadSessionBody" />
        <property name="param2_recordOrg" value="ballerinax" />
        <property name="param2_recordModule" value="microsoft.onedrive" />
        <property name="payload_param0" value="item.description"/>
        <property name="payload_paramType0" value="string"/>
        <property name="payload_param1" value="item.driveItemSource.application"/>
        <property name="payload_paramType1" value="enum"/>
        <property name="payload_param2" value="item.driveItemSource.externalId"/>
        <property name="payload_paramType2" value="string"/>
        <property name="payload_param3" value="item.fileSize"/>
        <property name="payload_paramType3" value="decimal"/>
        <property name="payload_param4" value="item.fileSystemInfo.createdDateTime"/>
        <property name="payload_paramType4" value="string"/>
        <property name="payload_param5" value="item.fileSystemInfo.lastAccessedDateTime"/>
        <property name="payload_paramType5" value="string"/>
        <property name="payload_param6" value="item.fileSystemInfo.lastModifiedDateTime"/>
        <property name="payload_paramType6" value="string"/>
        <property name="payload_param7" value="item.mediaSource.contentCategory"/>
        <property name="payload_paramType7" value="enum"/>
        <property name="payload_param8" value="item.name"/>
        <property name="payload_paramType8" value="string"/>
        <property name="param3" value="headers"/>
        <property name="paramType3" value="map"/>
        <property name="mapValueType3" value="union"/>
        <property name="paramSize" value="4"/>
        <property name="paramFunctionName" value="createUploadSession"/>
        <property name="returnType" value="union"/>
        <property name="functionType" value="REMOTE"/>
        <class name="io.ballerina.stdlib.mi.BalConnectorFunction">
            <property name="orgName" value="ballerinax"/>
            <property name="moduleName" value="microsoft.onedrive"/>
            <property name="version" value="3"/>
        </class>
    </sequence>
</template>
